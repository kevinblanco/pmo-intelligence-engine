# ─── GCP ─────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1

# ─── BigQuery ─────────────────────────────────────────────────────────────────
BIGQUERY_DATASET=pmo_intelligence

# ─── Asana REST ───────────────────────────────────────────────────────────────
# Personal Access Token — used by webhook_receiver and orchestrator for REST API
ASANA_PAT=
# GID of the "New Project Requests" Asana project (from the project URL)
ASANA_PROJECT_GID=
# Populated automatically by webhook_register.py (stored in Secret Manager)
ASANA_WEBHOOK_SECRET=

# ─── Asana MCP OAuth ──────────────────────────────────────────────────────────
# OAuth app credentials for the Asana MCP server (separate from PAT)
# Create at: app.asana.com/0/my-apps → Create new app → MCP app
ASANA_MCP_CLIENT_ID=
ASANA_MCP_CLIENT_SECRET=
# Tokens are stored in Secret Manager by mcp_auth_setup.py — do not put here

# ─── Cloud Run Service URLs ───────────────────────────────────────────────────
# Populated by deploy.sh after each service is deployed
WEBHOOK_RECEIVER_URL=
ORCHESTRATOR_URL=
BQ_ANALYST_URL=
RISK_SCORER_URL=
RESOURCE_ADVISOR_URL=
ASANA_CONTEXT_URL=

# ─── Model ────────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash-001
